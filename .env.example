# =============================================================================
# SGG Visualization Configuration
# =============================================================================
# Copy this file to .env and modify the values for your environment
# cp .env.example .env

# --- Application Settings ---
DEBUG=false
APP_NAME=SGG Visualization

# --- Database ---
# SQLite (default, recommended for single-user deployment)
DATABASE_URL=sqlite+aiosqlite:///./sgg_visualization.db

# PostgreSQL (uncomment for production multi-user deployment)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sgg_visualization

# --- Video Data Path (REQUIRED) ---
# Directory containing video samples with VSG files and frames
# Each subdirectory should be a video sample with the following structure:
#   {video_id}/
#     ├── outputs/video_scene_graph_*.json
#     ├── frames/0000.png, 0001.png, ...
#     └── masks/ (optional)
PVSG_MINI_PATH=/path/to/your/video/data

# --- Frame Cache (Optional but Recommended) ---
# Enable disk caching for faster frame loading during video playback
FRAME_CACHE_ENABLED=true

# Path to store cached frames
# Should be on fast storage (SSD recommended) with sufficient space
# Each video may use 50-500MB depending on frame count and resolution
FRAME_CACHE_PATH=/path/to/cache/sgg_frames

# --- CORS (Frontend URLs allowed to access the API) ---
# Add your frontend URL if deploying to a different domain or port
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# --- Pagination ---
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
